{
  "kind": "collectionType",
  "collectionName": "merchandises",
  "info": {
    "singularName": "merchandise",
    "pluralName": "merchandises",
    "displayName": "Merchandise",
    "description": "The merchandise products available"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "releaseDate": {
      "type": "date"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::merchandise-category.merchandise-category",
      "inversedBy": "merchandises"
    },
    "storeLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.store-link"
    }
  }
}